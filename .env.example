# Polkadot Hub Testnet (Passet Hub)
POLKADOT_HUB_RPC=https://testnet-passet-hub-eth-rpc.polkadot.io

# Your deployer/oracle wallet private key (no 0x prefix needed by forge)
PRIVATE_KEY=your_private_key_here

# Gemini AI (for AI oracle yield analysis)
GEMINI_API_KEY=your_gemini_api_key

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Oracle check interval in ms (default 5 minutes)
CHECK_INTERVAL_MS=300000
